            <mxPoint x="500" y="403" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3_err_box" value="404 Not Found&#xa;{ error: Blog not found }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="371" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s3_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="383" as="sourcePoint" />
            <mxPoint x="350" y="383" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4a_box" value="STEP 4a — GET: Fetch All Active Comments&#xa;&#xa;Comment.objects.by_blog(blog).select_related(&#39;user&#39;)&#xa;by_blog = filter(blog=blog, is_deleted=False)&#xa;is_deleted=False ensures soft-deleted comments are hidden" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="453" width="340" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s4a_db_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="481" as="sourcePoint" />
            <mxPoint x="840" y="481" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4a_db_box" value="Returns: active comments list" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="760" y="466" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s4a_db_ret" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="501" as="sourcePoint" />
            <mxPoint x="500" y="501" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4b_box" value="STEP 4b — POST: Validate + Save Comment&#xa;&#xa;CommentCreateSerializer: content required&#xa;comment = serializer.save(blog=blog, user=request.user)&#xa;blog and user injected from context — not from client" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="558" width="340" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s4b_db_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="586" as="sourcePoint" />
            <mxPoint x="840" y="586" as="targetPoint" />
          </mxGeometry>
        </mxCell>
