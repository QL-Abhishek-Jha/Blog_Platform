        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=18;fontColor=#000000;" value="COMMENT LIST + CREATE API — Low Level Design" vertex="1">
          <mxGeometry height="40" width="900" x="100" y="20" as="geometry" />
        </mxCell>
        <mxCell id="c_box" value="CLIENT (ANY / AUTH)" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=13;">
          <mxGeometry x="80" y="75" width="160" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s_box" value="BACKEND SERVER" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=13;">
