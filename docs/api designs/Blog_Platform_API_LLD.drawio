        <mxCell id="s3a_box" value="STEP 3a — GET: Fetch ALL Blogs (Drafts + Published)&#xa;&#xa;Blog.objects.all().select_related(&#39;author&#39;, &#39;topic&#39;)&#xa;Admin sees everything including other authors&#39; drafts" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
