          <mxGeometry x="840" y="120" width="2" height="790" as="geometry" />
        </mxCell>
        <mxCell id="s1_box" value="STEP 1 — Client Sends Comment Request&#xa;&#xa;GET  /api/blogs/{slug}/comments/   list comments (public)&#xa;POST /api/blogs/{slug}/comments/   add comment (auth required)&#xa;JWT validation skipped for GET via get_authenticators()" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="80" y="155" width="360" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s1_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="190" as="sourcePoint" />
            <mxPoint x="500" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_box" value="STEP 2 — Auth Split: GET vs POST&#xa;&#xa;GET: AllowAny — no token — get_authenticators() returns []&#xa;POST: IsAuthenticated — valid Bearer token required&#xa;Anyone can READ comments.  Must be signed in to WRITE." parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="260" width="340" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s2_err_box" value="401 Unauthorized (POST only)&#xa;{ error: Authentication credentials not provided }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="268" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s2_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="290" as="sourcePoint" />
            <mxPoint x="350" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3_box" value="STEP 3 — Verify Blog Exists and Is Published&#xa;&#xa;Blog.objects.filter(slug=slug, is_published=True).first()&#xa;Cannot comment on a draft blog&#xa;404 for both GET and POST if blog not found/draft" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="355" width="340" height="65" as="geometry" />
        </mxCell>
