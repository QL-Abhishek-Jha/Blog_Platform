            <mxPoint x="840" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4_db_box" value="Returns: user object  OR  None" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="760" y="435" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s4_db_ret" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
