            <mxPoint x="160" y="655" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s6_note" value="Note: All refresh tokens are blacklisted — all other devices are logged out for security." parent="1" vertex="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=2;">
