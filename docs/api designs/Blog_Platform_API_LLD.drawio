        <mxCell id="s2_box" value="STEP 2 — Authentication Check&#xa;&#xa;IsAuthenticated — valid Bearer token required" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
