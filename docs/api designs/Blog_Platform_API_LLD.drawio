        <mxCell id="ll_d" value="" parent="1" vertex="1" style="endArrow=none;dashed=1;strokeColor=#000000;strokeWidth=1;">
          <mxGeometry x="840" y="120" width="2" height="740" as="geometry" />
        </mxCell>
        <mxCell id="s1_box" value="STEP 1 — User/Admin Sends Delete Comment Request&#xa;&#xa;DELETE /api/blogs/comments/{comment_id}/&#xa;Headers: Authorization: Bearer &lt;access_token&gt;&#xa;No body required" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="80" y="155" width="360" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s1_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="188" as="sourcePoint" />
            <mxPoint x="500" y="188" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_box" value="STEP 2 — Authentication Check&#xa;&#xa;IsAuthenticated — valid Bearer token required&#xa;Must be logged in to delete any comment" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="250" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_err_box" value="401 Unauthorized&#xa;{ error: Authentication credentials not provided }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
