            <mxPoint x="500" y="373" as="sourcePoint" />
            <mxPoint x="350" y="373" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4_box" value="STEP 4 — Verify Old Password Correct&#xa;&#xa;user.check_password(old_password)&#xa;Must verify current password before allowing change" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="440" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s4_err_box" value="400 Bad Request&#xa;{ error: Old password is incorrect }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="447" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s4_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="465" as="sourcePoint" />
            <mxPoint x="350" y="465" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5_box" value="STEP 5 — Save New Password + Blacklist All Sessions&#xa;&#xa;user.set_password(new_password)  |  user.save()&#xa;_blacklist_all_user_tokens(user) — all existing&#xa;refresh tokens blacklisted (forces re-login everywhere)" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="525" width="340" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s5_db_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
