        <mxCell id="s1_box" value="STEP 1 — User Sends Change Password Request&#xa;&#xa;POST /api/auth/change-password/&#xa;Headers: Authorization: Bearer &lt;access_token&gt;&#xa;Body: { old_password, new_password, confirm_new_password }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="80" y="155" width="360" height="70" as="geometry" />
        </mxCell>
