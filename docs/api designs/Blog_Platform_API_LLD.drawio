          <mxGeometry x="760" y="571" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s4b_db_ret" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="606" as="sourcePoint" />
            <mxPoint x="500" y="606" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4b_err_box" value="400 Bad Request&#xa;{ content: This field is required }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="574" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s4b_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="586" as="sourcePoint" />
            <mxPoint x="350" y="586" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5_box" value="STEP 5 — Return Response&#xa;&#xa;GET → 200 OK  CommentSerializer  [ all active comments ]&#xa;POST → 201 Created  CommentSerializer  { new comment }&#xa;{ id, blog, user, username, content, is_deleted, created_at }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="80" y="673" width="360" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s5_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="706" as="sourcePoint" />
            <mxPoint x="160" y="706" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5_note" value="Note: is_deleted uses soft-delete.  CommentDeleteView sets is_deleted=True — row stays in DB." parent="1" vertex="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=2;">
          <mxGeometry x="390" y="694" width="460" height="18" as="geometry" />
