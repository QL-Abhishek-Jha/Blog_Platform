            <mxPoint x="500" y="188" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_box" value="STEP 2 — Permission Check&#xa;&#xa;AllowAny — no auth token required for this endpoint&#xa;authentication_classes = []  |  permission_classes = [AllowAny]" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="250" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s3_box" value="STEP 3 — Validate refresh_token Present&#xa;&#xa;refresh_token = request.data.get(&#39;refresh_token&#39;)&#xa;400 if not provided" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
