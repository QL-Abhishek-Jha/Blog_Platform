            <mxPoint x="350" y="275" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3_box" value="STEP 3 — Superadmin Role Check (IsSuperAdmin)&#xa;&#xa;request.user.is_superadmin == True ?&#xa;Only superadmin can create admin accounts&#xa;Regular admins CANNOT create other admins" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
