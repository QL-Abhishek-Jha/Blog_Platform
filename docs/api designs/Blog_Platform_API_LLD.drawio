            <mxPoint x="500" y="470" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4_err_box" value="401 Unauthorized&#xa;{ error: Refresh token is expired. code: token_expired }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="458" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s4_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="470" as="sourcePoint" />
            <mxPoint x="350" y="470" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5_box" value="STEP 5 — Blacklist Old Token + Issue New Pair&#xa;&#xa;old_refresh.blacklist()&#xa;new_refresh = RefreshToken.for_user(user)&#xa;ROTATE_REFRESH_TOKENS prevents token reuse" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
