            <mxPoint x="350" y="380" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4_box" value="STEP 4 — Check Duplicate Email and Username&#xa;&#xa;SELECT 1 FROM users WHERE email = ?&#xa;SELECT 1 FROM users WHERE username = ?" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
