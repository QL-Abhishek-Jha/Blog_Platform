          <mxGeometry x="840" y="120" width="2" height="890" as="geometry" />
        </mxCell>
        <mxCell id="s1_box" value="STEP 1 — Admin Sends User Management Request&#xa;&#xa;GET /api/admin/users/{user_id}/     view user&#xa;PATCH /api/admin/users/{user_id}/   update role/active&#xa;DELETE /api/admin/users/{user_id}/  delete user" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="80" y="155" width="360" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s1_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="190" as="sourcePoint" />
            <mxPoint x="500" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_box" value="STEP 2 — Authentication + Admin Role Check&#xa;&#xa;IsAuthenticated AND IsAdminUser&#xa;request.user.role == &#39;admin&#39; required" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="260" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_err_box" value="401 Unauthorized OR 403 Forbidden&#xa;{ error: Not authenticated or not admin role }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="262" width="270" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="285" as="sourcePoint" />
            <mxPoint x="350" y="285" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3_box" value="STEP 3 — Fetch Target User from Database&#xa;&#xa;User.objects.filter(id=user_id).first()" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="345" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s3_db_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="373" as="sourcePoint" />
            <mxPoint x="840" y="373" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3_db_box" value="Returns: user row  OR  None" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="760" y="358" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s3_db_ret" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="393" as="sourcePoint" />
            <mxPoint x="500" y="393" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3_err_box" value="404 Not Found&#xa;{ error: User not found }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="361" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s3_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="373" as="sourcePoint" />
            <mxPoint x="350" y="373" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4_box" value="STEP 4 — Protected Account Guard (PATCH + DELETE)&#xa;&#xa;user._is_protected()  checks role == &#39;admin&#39; or is_superadmin&#xa;Admin CANNOT modify another admin or superadmin account" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="428" width="340" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s4_err_box" value="403 Forbidden&#xa;{ error: Cannot modify admin or superadmin accounts }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="438" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s4_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="455" as="sourcePoint" />
            <mxPoint x="350" y="455" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5a_box" value="STEP 5a — GET: Serialize and Return User&#xa;&#xa;UserProfileSerializer(user)&#xa;Returns full profile including role and is_active" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="523" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s5b_box" value="STEP 5b — PATCH: Update Role or Active Status&#xa;&#xa;AdminUserUpdateSerializer — only role and is_active editable&#xa;Admin CANNOT set role to &#39;admin&#39; (only user/author allowed)" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="598" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s5b_err_box" value="400 Bad Request&#xa;{ role: You can only set role to &#39;user&#39; or &#39;author&#39; }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
          <mxGeometry x="80" y="606" width="270" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s5b_err_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="623" as="sourcePoint" />
            <mxPoint x="350" y="623" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5c_box" value="STEP 5c — DELETE: Hard Delete User&#xa;&#xa;user.delete()&#xa;CASCADE: deletes all user&#39;s blogs, comments, subscriptions" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="673" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s5_db_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="703" as="sourcePoint" />
            <mxPoint x="840" y="703" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5_db_box" value="Returns: OK — saved or deleted" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="760" y="688" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s5_db_ret" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="723" as="sourcePoint" />
            <mxPoint x="500" y="723" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s6_box" value="STEP 6 — Return Response&#xa;&#xa;GET/PATCH → 200 OK  { user profile }&#xa;DELETE → 204 No Content" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="80" y="778" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s6_arr" value="" parent="1" vertex="1" edge="1" style="endArrow=open;endFill=0;strokeColor=#000000;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="805" as="sourcePoint" />
