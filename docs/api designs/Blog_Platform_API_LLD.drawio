  <diagram name="DELETE COMMENT API" id="deletecomment">
    <mxGraphModel dx="2246" dy="1094" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
