        </mxCell>
        <mxCell id="c_box" value="CLIENT (AUTH USER)" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=13;">
