          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="190" as="sourcePoint" />
            <mxPoint x="500" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s2_box" value="STEP 2 — Authentication Check&#xa;&#xa;IsAuthenticated — valid Bearer token required&#xa;Anonymous users cannot change passwords" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;">
          <mxGeometry x="390" y="260" width="340" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2_err_box" value="401 Unauthorized&#xa;{ error: Authentication credentials not provided }" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;align=left;spacingLeft=8;fontStyle=0;;dashed=1;">
